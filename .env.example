# Required for story generation
ANTHROPIC_API_KEY=

# Required for image generation
OPENAI_API_KEY=

# Set to 'true' to use stub/mock data instead of real AI calls
USE_STUBS=true

# Optional: ElevenLabs TTS (stub used if not set)
ELEVENLABS_API_KEY=

# NextAuth.js (required for auth)
NEXTAUTH_SECRET=change-this-to-a-random-string
NEXTAUTH_URL=http://localhost:3000
