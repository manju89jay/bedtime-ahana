{
  "name": "bedtime-ahana",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "format": "prettier --write .",
    "coverage": "node scripts/run-coverage.mjs",
    "build:all": "bash ./scripts/build-all.sh",
